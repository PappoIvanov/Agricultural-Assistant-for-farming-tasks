.env
__pycache__/
*.pyc

# Лични данни и оперативни записи — не влизат в репото
01_Дневник_Операции/*
!01_Дневник_Операции/Диагностичен_дневник.md
02_Администрация/
04_Парцели/
07_Photos/
планирани_пръскания.json

# 06_Техника — PDF-ите са твърде големи, само MD (конвертирани) влизат в git
06_Техника/**/*.pdf

# 03_Препарати_и_Торове — изключи всичко...
03_Препарати_и_Торове/*
# ...но отключи пътя до БАБХ регистъра ниво по ниво
!03_Препарати_и_Торове/Литература/
03_Препарати_и_Торове/Литература/*
!03_Препарати_и_Торове/Литература/Разрешени_препарати_БАБХ/
03_Препарати_и_Торове/Литература/Разрешени_препарати_БАБХ/*
!03_Препарати_и_Торове/Литература/Разрешени_препарати_БАБХ/2026/
03_Препарати_и_Торове/Литература/Разрешени_препарати_БАБХ/2026/*
!03_Препарати_и_Торове/Литература/Разрешени_препарати_БАБХ/2026/PPP+Register_BFSA+12.03.2026.md

# 05_Литература — изключи всичко по подразбиране...
05_Литература/*
05_Литература/**/*

# ...но включи ключовите файлове за агента
!05_Литература/База_знания.md

# 08_AI_Model — снимки, модели и резултати са твърде тежки за git
08_AI_Model/datasets/
08_AI_Model/models/
08_AI_Model/runs/
# Скриптовете и конфигурациите влизат в git (те са малки текстови файлове)
!08_AI_Model/scripts/
!08_AI_Model/configs/
!08_AI_Model/README.md
